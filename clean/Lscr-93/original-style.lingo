      sprite(flashSP).activatePurchaseCB(s, response.getAProp("m"), response.getAProp("p"), response.getAProp("ma"), response.getAProp("va"), response.getAProp("d"))
    else
      sprite(flashSP).activatePurchaseCB(s)
