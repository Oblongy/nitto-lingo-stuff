    sprite(flashSP).buyFromClassifiedCB(response.getAProp("s"), response.getAProp("d"))

  else if action = "classifiedhistory" then
    sprite(flashSP).sellerClassifiedHistoryCB(response.getAProp("d"))

  else if action = "cancelclassified" then
    sprite(flashSP).cancelClassifiedCB(response.getAProp("s"), response.getAProp("d"))

  else if action = "requesttrade" then
    sprite(flashSP).requestTradeCB(response.getAProp("s"), response.getAProp("d"))

  else if action = "respondtrade" then
    sprite(flashSP).respondTradeCB(response.getAProp("s"), response.getAProp("d"))

  else if action = "canceltrade" then
    sprite(flashSP).cancelTradeCB(response.getAProp("s"), response.getAProp("d"))

  else if action = "getoutgoingtradehistory" then
    sprite(flashSP).outgoingTradeHistoryCB(response.getAProp("d"))

  else if action = "getpendingtrades" then
    sprite(flashSP).pendingTradesCB(response.getAProp("d"))

  else if action = "getwinsandlosses" then
    sprite(flashSP).getWinsAndLossesCB(response.getAProp("d"))

  else if action = "earnincentive" then
    sprite(flashSP).earnIncentiveCB(response.getAProp("s"), response.getAProp("b"))

  else if action = "logintwitter" then
    sprite(flashSP).loginTwitterCB(response.getAProp("s"), response.getAProp("u"))

  else if action = "setbadgevisible" then
    sprite(flashSP).setBadgeVisibleCB(response.getAProp("s"))

  else if action = "getblackcardprogress" then
    sprite(flashSP).getBlackCardProgressCB(response.getAProp("d"))

  -- -----------------------------------------------------------------------
  -- Election / Support / News
  -- -----------------------------------------------------------------------

  else if action = "getelectionphase" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).getElectionPhaseCB(TRUE, response.getAProp("p"), response.getAProp("t"), response.getAProp("i"))
    else
      sprite(flashSP).getElectionPhaseCB(s, VOID, VOID, response.getAProp("i"))
    end if

  else if action = "getelectionschedule" then
    sprite(flashSP).getElectionScheduleCB(response.getAProp("d"))

  else if action = "getnominatecount" then
    sprite(flashSP).getNominateCountCB(response.getAProp("c"))

  else if action = "nominate" then
    sprite(flashSP).nominateCB(response.getAProp("s"), response.getAProp("e"))

  else if action = "getelectionresult" then
    sprite(flashSP).getElectionResultCB(response.getAProp("d"))

  else if action = "electionvote" then
    sprite(flashSP).electionVoteCB(response.getAProp("s"), response.getAProp("e"))

  else if action = "activateaccount" then
    sprite(flashSP).activateAccountCB(response.getAProp("s"), response.getAProp("e"))

  else if action = "getsupport" then
    sprite(flashSP).getSupportCB(response.getAProp("s"), response.getAProp("m"), response.getAProp("i"), response.getAProp("t"))

  else if action = "getmisconductcount" then
    sprite(flashSP).getMisconductCountCB(response.getAProp("oid"), response.getAProp("n"), response.getAProp("t"))

  -- -----------------------------------------------------------------------
  -- Facebook
  -- -----------------------------------------------------------------------

  else if action = "fbgettoken" then
    _global.facebookToken = response.getAProp("t")
    _global.facebookAPIKey = response.getAProp("a")
    openURL((((("https://login.facebook.com/login.php?api_key=" & _global.facebookAPIKey) & "&auth_token=") & _global.facebookToken) & "&v=1.0&popup&req_perms=offline_access"))
    sprite(flashSP).fbGetTokenCB(response.getAProp("s"))

  else if action = "fbremovefacebook" then
    sprite(flashSP).fbRemoveFacebookCB(response.getAProp("s"))

  else if action = "fbgetinviteurl" then
    d = response.getAProp("d")
    trace("here!")
    trace("info list!")
    trace(d)
    openURL("http://www.facebook.com/multi_friend_selector.php/?api_key=75142a34f8f8698fb895c3156093f9c8&content=This network is the best place on Facebook for viewing", _blank)

  -- -----------------------------------------------------------------------
  -- Test Drive
  -- -----------------------------------------------------------------------

  else if action = "checktestdrive" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).checkTestDriveCB(s, response.getAProp("d"))
    else
      sprite(flashSP).checkTestDriveCB(s)
    end if

  else if action = "accepttestdrive" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).acceptTestDriveCB(s, response.getAProp("h"), response.getAProp("m"), response.getAProp("p"), response.getAProp("d"))
    else
      sprite(flashSP).acceptTestDriveCB(s)
    end if

  else if action = "buytestdrivecar" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).buyTestDriveCarCB(s, response.getAProp("b"))
    else
      sprite(flashSP).buyTestDriveCarCB(s)
    end if

  else if action = "removetestdrivecar" then
    sprite(flashSP).removeTestDriveCarCB(response.getAProp("s"))

  else if action = "rejecttestdrive" then
    sprite(flashSP).rejectTestDriveCB(response.getAProp("s"))

  else if action = "changeshiftlightrpm" then
    sprite(flashSP).changeShiftLightRpmCB(response.getAProp("s"))

  -- -----------------------------------------------------------------------
  -- Special Events / News / Spotlight
  -- -----------------------------------------------------------------------

  else if action = "joinspecialevent" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).joinSpecialEventCB(s, response.getAProp("b"), response.getAProp("d"))
    else
      sprite(flashSP).joinSpecialEventCB(s)
    end if

  else if action = "getnews" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).getNewsCB(s, response.getAProp("d"))
    else
      sprite(flashSP).getNewsCB(s)
    end if

  else if action = "getspotlightracers" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).getSpotlightRacersCB(s, response.getAProp("d"))
    else
      sprite(flashSP).getSpotlightRacersCB(s)
    end if

  else if action = "claimpendinguclprofit" then
    sprite(flashSP).claimPendingUCLProfitCB(response.getAProp("s"), response.getAProp("b"))

  -- -----------------------------------------------------------------------
  -- Late queue tail: installed engine parts / avatars / cache / installer
  -- -----------------------------------------------------------------------

  else if action = "getinstalledenginepartbyaccountcar" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).getInstalledEnginePartsCB(s, response.getAProp("d"))
    else
      sprite(flashSP).getInstalledEnginePartsCB(s)
    end if

  else if action = "gettotalnewmail" or action = "getemaillist" or action = "getavatarage" or action = "getteamavatarage" then
    sprite(flashSP).genericWebCB(_global.gNetID[_global][VOID], response.getAProp("s"), response.getAProp("d"))

  else if action = "avatars" or action = "teamavatars" then
    loadLocalAvatar(_global.fileNetID[_global], _global.fileNetID[_global][VOID], 1)

  else if action = "ugg" then
    loadLocalUgg(_global.fileNetID[_global], 1)

  else if action = "cache" then
    downloadCacheInProgress(getStreamStatus(_global.fileNetID[_global][netDone]))

  else if action = "installer" then
    runInstaller(_global.fileNetID[_global])

  end if

  _global.gNetID.splice(_global, TRUE)

end
