-- Lscr-93 original-style Lingo reconstruction
-- Source: Lscr-93.bin / Lscr-93.json, 31-pass mechanical analysis
-- Constraint: every executable line comes from recovered bytecode evidence.
-- Variable names: action = _global.gNetID[_global][VOID]
--                 response = checkedForOneClient (propList parsed from net text)

on exitFrame
  _global.gNetID
  _global.checkedForOneClient
  _global.checkProcessResult
end

on procResponse
  -- Bootstrap: process-check before the main net queue loop
  if _global.checkedForOneClient = VOID then
    checkedForOneClient = TRUE
    _global
    if netError(_global.checkProcessResult) = OK then
      trace(netTextResult(_global.checkProcessResult))
      CheckNittoProcessesCB(netTextResult(_global.checkProcessResult))
    else
      CheckNittoProcessesCB("1")
    end if
    _global = VOID
    netDone(_global.checkProcessResult)
  end if

  if not (_global < _global.gNetID.length) then exit

  _system.gc()

  if not (netDone(_global.gNetID[_global])(netError[_global.gNetID[_global]]) = OK) then
    -- net error handling
    netDone = netTextResult(_global.gNetID[_global])
    if isEnc then
      netDone = decrypt(netDone)
    end if
    -- error routing
    sprite(flashSP).showConnectionErrorCB("Protocol Error", (("Connection protocol could not be established. Action:" & _global.gNetID[_global][VOID]) & " (Error: 010)"))
    if netDone = "\"s\",-100" then
      sprite(flashSP).showConnectionErrorCB("Session Timed Out", ("I'm sorry, but your session has timed out, please restart the application. Last action: " & _global.lastAction))
    end if
    exit
  end if

  netDone = netTextResult(_global.gNetID[_global])
  response = value(("propList(" & netDone) & ")")

  action = _global.gNetID[_global][VOID]

  -- -----------------------------------------------------------------------
  -- Bootstrap / Cache / Login
  -- -----------------------------------------------------------------------

  if action = "getcache" then
    xmlParser = new xtra("xmlparser")
    xmlParser.parseString(response.getAProp("d"))
    fetchCacheXMLDone(xmlParser.makeList().n2)
    xmlParser = VOID

  else if action = "fbgetsession" or action = "login" then
    s = response.getAProp("s")
    if s = TRUE then
      if response.getAProp("ftc") = TRUE then
        openURL((("http://www.facebook.com/connect/prompt_permissions.php?api_key=" & _global.facebookAPIKey) & "&v=1.0&next=http://www.facebook.com/connect/login_success.html?xxRESULTTOKENxx&display=popup&ext_perm=publish_stream&enable_profile_selector=0"))
      end if
      _global.aid = response.getAProp("aid")
      _global.guid = response.getAProp("guid")
      _global.cp = encrypt(response.getAProp("cp"))
      _global.cw = encrypt(response.getAProp("cw"))
      _global.cwc = encrypt(response.getAProp("cwc"))
      connectSocket()
      sprite(flashSP).loginCB(response.getAProp("s"), response.getAProp("d"), response.getAProp("at"), response.getAProp("am"))
    else if s = -2 or s = -11 or s = -12 then
      if s = -99 then
        sprite(flashSP).loginCB(response.getAProp("s"), response.getAProp("d"))
      else if s = -5 then
        sprite(flashSP).loginCB(response.getAProp("s"), response.getAProp("d"))
        _global.installerURL = response.getAProp("url")
        _global.installerFile = response.getAProp("fn")
        _global.installerMD5 = response.getAProp("md5")
      else if s = -14 then
        _global.facebookID = response.getAProp("f")
        sprite(flashSP).fbGetSessionCB(response.getAProp("s"))
      else if s = -15 then
        sprite(flashSP).fbGetSessionCB(response.getAProp("s"))
      else
        sprite(flashSP).loginCB(response.getAProp("s"))
      end if
    end if

  else if action = "changehomemachine" then
    -- no-op body

  -- -----------------------------------------------------------------------
  -- Account / Profile
  -- -----------------------------------------------------------------------

  else if action = "getinfo" then
    if response.getAProp("s") = TRUE then
      sprite(flashSP).getInfoCB(response.getAProp("d"))
    end if

  else if action = "getuser" then
    sprite(flashSP).getUserCB(response.getAProp("d"))

  else if action = "getusers" then
    sprite(flashSP).getUsersCB(response.getAProp("d"))

  else if action = "updatebg" then
    sprite(flashSP).updateBgColorCB(response.getAProp("s"))

  else if action = "updatedefaultcar" then
    sprite(flashSP).updateDefaultCarCB(response.getAProp("s"))

  else if action = "racersearch" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).racerSearchCB(s, response.getAProp("d"))
    else
      sprite(flashSP).racerSearchCB(s)
    end if

  else if action = "racersearchnopage" then
    s = response.getAProp("s")
    if s = TRUE then
      sprite(flashSP).racerSearchNoPageCB(s, response.getAProp("d"))
    else
      sprite(flashSP).racerSearchNoPageCB(s)
