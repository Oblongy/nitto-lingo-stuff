on __Lscr102_block00_RaceEngineConstructor
  -- Block 0 is a constructor/registration table. It repeatedly loads a common
  -- object/function context, indexes even-numbered implementation slots, and
  -- stores odd-numbered function objects. This likely creates the RaceEngine
  -- object returned by the public RaceEngine() handler.

  engine = [:]

  engine[#initConstants] = __Lscr102_block01_initConstants
  engine[#initRaceState] = __Lscr102_block02_initRaceState
  engine[#loadCarXML] = __Lscr102_block03_loadCarXML
  engine[#calculateBoostRange] = __Lscr102_block04_calculateBoostRange
  engine[#forgetSendInterval] = __Lscr102_block05_forgetSendInterval
  engine[#forgetRunInterval] = __Lscr102_block06_forgetRunInterval
  engine[#runStagingState] = __Lscr102_block07_runStagingState
  engine[#runEngineFrame] = __Lscr102_block08_runEngineFrame
  engine[#calculateBoostPower] = __Lscr102_block09_calculateBoostPower
  engine[#getTorque] = __Lscr102_block10_getTorque
  engine[#initBtd] = __Lscr102_block11_initBtd
  engine[#updateGearAndSpeedUI] = __Lscr102_block12_updateGearAndSpeedUI
  engine[#shiftGear] = __Lscr102_block13_shiftGear
  engine[#setBrake] = __Lscr102_block14_setBrake
  engine[#setClutch] = __Lscr102_block15_setClutch
  engine[#updateRaceTimingCounters] = __Lscr102_block16_updateRaceTimingCounters
  engine[#scheduleStagingLights] = __Lscr102_block17_scheduleStagingLights
  engine[#runStagingLight] = __Lscr102_block18_runStagingLight
  engine[#initDynoAndConfig] = __Lscr102_block19_initDynoAndConfig
  engine[#randomMathHelper] = __Lscr102_block20_randomMathHelper

  return engine
end


