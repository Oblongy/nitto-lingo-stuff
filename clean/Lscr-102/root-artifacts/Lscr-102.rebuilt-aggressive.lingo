on __Lscr102_block03_loadCarXML carXML
  -- Recovered parser path:
  --   xtra("xmlparser")
  --   parseString
  --   makeList
  --   parseInt / parseFloat
  -- plus many setup fields.

  parser = xtra("xmlparser")
  parser.parseString(carXML)

  xmlList = parser.makeList()
  attrs = xmlList.getAProp("!ATTRIBUTES")

  w = attrs.getAProp("w")
  r = attrs.getAProp("r")
  hpi = parseInt(attrs.getAProp("hpi"))
  stockRedLine = parseInt(attrs.getAProp("stockRedLine"))
  redLine = parseInt(attrs.getAProp("redLine"))
  revLimiter = parseInt(attrs.getAProp("revLimiter"))
  detuneHp = parseFloat(attrs.getAProp("detuneHp"))

  UsInit = parseFloat(attrs.getAProp("UsInit"))
  UkInit = parseFloat(attrs.getAProp("UkInit"))
  stockBoost = parseFloat(attrs.getAProp("stockBoost"))
  boostSetting = parseFloat(attrs.getAProp("boostSetting"))
  boostType = attrs.getAProp("boostType")
  initBoost = parseFloat(attrs.getAProp("initBoost"))

  grs = attrs.getAProp("grs")
  if voidP(grs) then
    grs = []
  end if
  fgr = parseFloat(attrs.getAProp("fgr"))

  NOS = attrs.getAProp("NOS")
  nitrousRemaining = parseFloat(attrs.getAProp("nitrousRemaining"))
  nitrousTankSize = parseFloat(attrs.getAProp("nitrousTankSize"))

  turboFlow = parseFloat(attrs.getAProp("turboFlow"))
  fuelFlowLimit = parseFloat(attrs.getAProp("fuelFlowLimit"))
  overallAirFlowLimit = parseFloat(attrs.getAProp("overallAirFlowLimit"))
  airFlowLimit = parseFloat(attrs.getAProp("airFlowLimit"))
  chipSetting = parseFloat(attrs.getAProp("chipSetting"))
  maxPsi = parseFloat(attrs.getAProp("maxPsi"))
  pistonCompressionLevel = parseFloat(attrs.getAProp("pistonCompressionLevel"))

  pistonDurability = parseFloat(attrs.getAProp("pistonDurability"))
  rodDurability = parseFloat(attrs.getAProp("rodDurability"))
  valveDurability = parseFloat(attrs.getAProp("valveDurability"))
  headGasketDurability = parseFloat(attrs.getAProp("headGasketDurability"))
  engineBlockDurability = parseFloat(attrs.getAProp("engineBlockDurability"))
  oilDurability = parseFloat(attrs.getAProp("oilDurability"))

  __Lscr102_block04_calculateBoostRange()
  setClutch(0)

  return VOID
end


on __Lscr102_block04_calculateBoostRange
  -- Names: boostType, T, boostLag, c0_7, boostSetting, boostRange, c1_7, c0.
  if boostType = "T" then
    boostRange = boostSetting * 1.7
    boostLag = boostSetting * 0.7
  else
    boostRange = boostSetting
    boostLag = 0
  end if

  return boostRange
end


on __Lscr102_block05_forgetSendInterval
  -- Names: runInterval, object, forget, timeout, sendInterval, symbol, sendPos.
  if sendInterval <> VOID then
    sendInterval.forget()
  end if
  sendInterval = timeout("sendPos")
  return VOID
end


on __Lscr102_block06_forgetRunInterval
  -- Names: runInterval, object, forget.
  if runInterval <> VOID then
    runInterval.forget()
  end if
  return VOID
end


on __Lscr102_block07_runStagingState
  -- Names: staging, rt, c1, raceType, KOTH, RIVAL, TEAMRIVAL, HT,
  -- gearValue, STG, carV, carAccel, c1320, timeAnchor, INT,
  -- _system, milliseconds.

  if staging then
    rt = _system.milliseconds - timeAnchor
  end if

  if raceType = "KOTH" or raceType = "RIVAL" or raceType = "TEAMRIVAL" or raceType = "HT" then
    -- Special race modes alter staging and elapsed-time handling.
    staging = 1
  end if

  if gearValue > 0 and carV >= 1320 then
    staging = 0
    carAccel = 0
  end if

  return rt
end


on __Lscr102_block08_runEngineFrame
  -- Main physics loop. This is the largest block and carries the real engine
  -- simulation. Exact branch nesting is still approximate, but the recovered
  -- names and repeated stores are very strong.

  theTime = _system.milliseconds
  timeFromLastFrame = theTime - timeAnchor
  theActualTime = timeFromLastFrame / 1000.0
  timeAnchor = theTime

  fpsCount = fpsCount + 1
  avgFps = (avgFps + timeFromLastFrame) / 2.0

  extraPower = calculateExtraHpi()
  boostCreatedPower = __Lscr102_block09_calculateBoostPower(rpm)
  -- Pass 5 resolved the core power cluster:
  --   hpi + boostCreatedPower + systemPower + ECUtune + compressionPowerDelta
  -- The exact accumulator naming is still stack-dependent, but these are the
  -- contributing terms.
  systemPower = hpi + boostCreatedPower + ECUtune + compressionPowerDelta + extraPower

  -- NOS path is confirmed by `NOS`, `runEngineNOSCB`, `nitrousRemaining`,
  -- `nitrousTankSize`, `raceGas`, and `c0_02`.
  if isNos and NOS and nitrousRemaining > 0 then
    availableNitrousPower = min(nitrousTankSize, nitrousRemaining)
    nitrousRemaining = nitrousRemaining - (0.02 * raceGas)
    runEngineNOSCB(nitrousRemaining)
  else
    availableNitrousPower = 0
  end if

  tq = __Lscr102_block10_getTorque(rpm)

  engineAccel = tq + systemPower + availableNitrousPower - detuneHp
  engineResistance = brake * brakeDecleration
  carAccel = engineAccel - engineResistance

  if clutchFeather > 0 then
    carAccel = carAccel * clutchFeather
  end if

  carV = carV + (carAccel * theActualTime)
  -- Pass 5 confirms car velocity conversion through vToMph and later traction
  -- coefficients UsInit / UkInit / tireStick.
  mph = carV * vToMph
  speedoV = mph
  engineV = rpmGearConversion * gearValue * carV

  if rpm > revLimiter then
    engineV = engineV - revLimiterDeceleration
  end if

  if engineDamageRisk > 0 then
    engineDamage = engineDamage + engineDamageRisk
  end if

  if engineDamage > 0 then
    isEngineLightOn = 1
  end if

  __Lscr102_block12_updateGearAndSpeedUI()

  return carV
end


on __Lscr102_block09_calculateBoostPower rpm
  -- Names: rpm, pb, stockBoost, boostSetting, boostRange, boostLag, boostPsi,
  -- compressionPowerDelta, pistonCompressionLevel, maxPsi, turboFlow,
  -- fuelFlowLimit, airFuelMeter, airFuelDelta, engineDamageRisk,
  -- boostCreatedPower.

  -- Prototype stack pass shows `rpm / pb`, then boost lag/range shaping.
  -- Exact curve is still approximate, but variable dependencies are strong.
  pb = rpm / pb
  if pb < 1 then
    pb = 1
  end if

  boostPsi = stockBoost + (boostSetting * pb)

  if boostLag > 0 then
    boostPsi = boostPsi - (boostLag * pb)
  end if

  if boostPsi < 0 then
    boostPsi = 0
  end if

  if boostPsi > maxPsi then
    boostPsi = maxPsi
  end if

  compressionPowerDelta = boostPsi * pistonCompressionLevel
  airFlowLimit = overallAirFlowLimit
  if fuelFlowLimit < airFlowLimit then
    airFlowLimit = fuelFlowLimit
  end if

  airFuelMeter = airFlowLimit - fuelFlowLimit
  airFuelDelta = abs(airFuelMeter)

  if airFuelDelta > dangerLevel then
    if boostPsi > 5 then
      engineDamageRisk = airFuelDelta * 0.09
    else
      engineDamageRisk = airFuelDelta * 0.07
    end if
  else
    engineDamageRisk = 0
  end if

  ECUtune = chipSetting / 100.0
  systemPower = airhpi * ((airFlowLimit - stockBoost / 2.0) / 100.0)
  boostCreatedPower = (pb * boostSetting) / 100.0
  return boostCreatedPower
end


on __Lscr102_block10_getTorque rpm
  -- Names: rpm, undefined, idleRPM, c10000, posTq, tqArray, parseInt,
  -- c100, negTq, c200.
  if voidP(rpm) then
    rpm = idleRPM
  end if

  if rpm < idleRPM then
    rpm = idleRPM
  end if

  if rpm > 10000 then
    rpm = 10000
  end if

  posTq = parseInt(rpm / 100)
  negTq = posTq + 200

  if posTq < 1 then
    posTq = 1
  end if

  if negTq > tqArray.count then
    negTq = tqArray.count
  end if

  -- `negTq = posTq + 200` is recovered from the stack prototype. The original
  -- likely keeps positive/negative torque curves in one array.
  if tqArray.count >= negTq then
    return (tqArray[posTq] + tqArray[negTq]) / 2.0
  end if

  return tqArray[posTq]
end


on __Lscr102_block11_initBtd
  init()
  btd = VOID
  return btd
end


on __Lscr102_block12_updateGearAndSpeedUI
  -- Names: gearValue, grs, mph, carAccel, carV, slip, sprite, flashSP,
  -- runEngineTractionLightCB, engineV, speedoV, hp, runEngineGearUpdateCB.

  if gearValue > 0 and gearValue <= grs.count then
    gr = grs[gearValue]
  else
    gr = 0
    mph = 0
    carAccel = 0
    carV = 0
  end if

  slip = carAccel > carV and gearValue > 0
  sprite(flashSP).runEngineTractionLightCB(slip)
  sprite(flashSP).runEngineGearUpdateCB(gearValue, engineV, speedoV, hp)

  return VOID
end


on __Lscr102_block13_shiftGear direction
  -- Block 13's table exposes only gearValue, but adjacent handlers and the
  -- Race Engine from C handler list make this the gear up/down implementation.
  oldGear = gearValue
  gearValue = gearValue + direction

  if gearValue < 0 then
    gearValue = 0
  end if

  if gearValue > grs.count then
    gearValue = grs.count
  end if

  if gearValue <> oldGear then
    rpm = rpm * 0.65
    __Lscr102_block12_updateGearAndSpeedUI()
  end if

  return gearValue
end


on __Lscr102_block14_setBrake brakeState
  if brakeState then
    brake = 1
  else
    brake = 0
  end if
  return brake
end


on __Lscr102_block15_setClutch clutchValue
  -- Constants recovered: c0_05, clutchFeather, c0_2.
  clutchFeather = clutchValue

  if clutchFeather < 0.05 then
    clutchFeather = 0.05
  end if

  if clutchFeather > 0.2 then
    clutchFeather = 0.2
  end if

  return clutchFeather
end


on __Lscr102_block16_updateRaceTimingCounters
  -- Names: timeAnchor, goodCounterRT, badCounterRT, goodCounterET,
  -- badCounterET, lightDelayTO, staging, gearValue.
  if lightDelayTO <> VOID then
    lightDelayTO.forget()
  end if

  if staging and gearValue > 0 then
    goodCounterRT = goodCounterRT + 1
  else
    badCounterRT = badCounterRT + 1
  end if

  if carV >= 1320 then
    goodCounterET = goodCounterET + 1
  else
    badCounterET = badCounterET + 1
  end if

  if raceType = "KOTH" or raceType = "RIVAL" or raceType = "TEAMRIVAL" then
    -- Block 16 also references createMd5Hash, QM, RREADY, KREADY and related
    -- race states. This is where result/counter integrity is prepared.
    createMd5Hash = string(goodCounterRT) & ":" & string(goodCounterET) & ":" & string(badCounterRT) & ":" & string(badCounterET)
  end if

  return VOID
end


on __Lscr102_block17_scheduleStagingLights
  -- Names: greenDelay, setSpectateDelayCB, timeAnchor, _system.milliseconds,
  -- lightTO1, object, forget, stagingLightPos1, timeout, symbol, runLight,
  -- secondBuffer, lightTO2, stagingLightPos2.
  timeAnchor = _system.milliseconds
  sprite(flashSP).setSpectateDelayCB(greenDelay)

  if lightTO1 <> VOID then
    lightTO1.forget()
  end if
  if lightTO2 <> VOID then
    lightTO2.forget()
  end if

  p = parseInt(greenDelay)
  b = p + secondBuffer

  lightTO1 = timeout("runLight", p, #runLight)
  lightTO2 = timeout("runLight", b, #runLight)
  stagingLightPos1 = p
  stagingLightPos2 = b

  return VOID
end


on __Lscr102_block18_runStagingLight period, name
  -- Names: runEngineSetLightOnCB, amber1/2/3, greenDelay, timeGreen,
  -- raceStartTimeCB, raceType.

  sprite(flashSP).runEngineSetLightOnCB(name, 1)

  case name of
    "amber1":
      amber1 = 1
    "amber2":
      amber2 = 1
    "amber3":
      amber3 = 1
    "green":
      green = 1
  end case

  if period >= greenDelay or name = "green" then
    timeGreen = _system.milliseconds
    sprite(flashSP).raceStartTimeCB(timeGreen, raceType)
  end if

  if raceType = "CT" then
    sprite(flashSP).ctStartAnimateComputerCB()
  end if

  if lightTO1 <> VOID and name = "green" then
    lightTO1.forget()
  end if
  if lightTO2 <> VOID and name = "green" then
    lightTO2.forget()
  end if

  return VOID
end


on __Lscr102_block19_initDynoAndConfig
  -- Dense configuration initializer. This block overlaps heavily with car XML
  -- fields and dyno/race physics constants.

  stockRedLine = redLine
  detuneHp = detuneHp
  stockBoost = stockBoost
  boostType = boostType
  boostSetting = boostSetting
  grs = grs
  fgr = fgr

  NOS = NOS
  nitrousTankSize = nitrousTankSize
  maxPsi = maxPsi
  hpi = hpi
  airhpi = airhpi
  turboFlow = turboFlow
  fuelFlowLimit = fuelFlowLimit

  engineBlockDurability = engineBlockDurability
  rpmGearConversion = rpmGearConversion
  brakeDecleration = brakeDecleration
  idleRPM = idleRPM
  engineDamage = 0

  -- MD5/check telemetry is present in this block:
  --   xtra, caluMD5, getStringMD5, guid, good/bad counters, lagPercent,
  --   nogood. This probably builds a race-integrity checksum over key engine
  --   parameters and counters.
  if objectP(xtra("caluMD5")) then
    guid = caluMD5_getStringMD5(string(stockRedLine) & "," & string(detuneHp) & "," & string(stockBoost))
  end if

  return VOID
end


on __Lscr102_block20_randomMathHelper
  -- Names: Math, log, random, round, constants c1, c5, c0_6, c2, c1000.
  return round((Math.log(random(1000) + 1) * 0.6) + 2)
end
