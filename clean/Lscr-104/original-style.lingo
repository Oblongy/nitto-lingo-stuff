-- Rival Race
-- -----------------------------------------------------------------------

on GETRIVALS p1, p2
  ssm("KR" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2)
end

on RREQ
  ssm(GR)
end

on RRSP p1, p2, p3, p4, p5
  ssm("RRQ" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & \
      String.fromCharCode(30) & p3 & String.fromCharCode(30) & p4 & \
      String.fromCharCode(30) & p5)
end

on RLVE p1, p2, p3
  ssm("RRS" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & String.fromCharCode(30) & p3)
end

on RIVOK
  ssm(RL)
end

on RIVREADY
  ssm(RO)
  _global.objRace.init(RIVAL)
end

on RIVRT p1, p2
  ssm("RR" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2)
end

on RIVDONE rt, rd
  rt = Math.floor(rt * 1000) / 1000
  ssm("RIVRT" & String.fromCharCode(30) & rt & String.fromCharCode(30) & rd)
end

-- -----------------------------------------------------------------------
-- Human Tournament (HT)
-- -----------------------------------------------------------------------

on HTJOIN rt, rd, p1, p2, p3, p4, p5, p6, p7, p8, p9, p10, p11, p12, p13, p14, p15
  rt = Math.floor(rt * 1000) / 1000
  rd = Math.floor(rd * 100) / 100
  afterRD = Math.floor(afterRD * 1000) / 1000
  trace("before RD")
  trace(decrypt(_global.cwc))
  trace(CheckWindows(decrypt(_global.cw)))
  trace(CheckWindowsClass(decrypt(_global.cwc)))
  ssm("RD" & String.fromCharCode(30) & rt & String.fromCharCode(30) & rd & \
      String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & \
      String.fromCharCode(30) & p3 & String.fromCharCode(30) & p4 & \
      String.fromCharCode(30) & p5 & String.fromCharCode(30) & p6 & \
      String.fromCharCode(30) & p7 & String.fromCharCode(30) & p8 & \
      String.fromCharCode(30) & p9 & String.fromCharCode(30) & p10 & \
      String.fromCharCode(30) & p11 & String.fromCharCode(30) & p12 & \
      String.fromCharCode(30) & p13 & String.fromCharCode(30) & isCheatEngineRunning() & \
      String.fromCharCode(30) & afterRD & \
      String.fromCharCode(30) & CheckProcesses(decrypt(_global.cp)) & \
      String.fromCharCode(30) & CheckWindows(decrypt(_global.cw)) & \
      String.fromCharCode(30) & CheckWindowsClass(decrypt(_global.cwc)))
  trace("after RD")
end

on HQOK qualifyID
  ssm("JT" & String.fromCharCode(30) & qualifyID)
end

on HTGET32 qualifyID
