-- Lscr-104 original-style Lingo reconstruction
-- Source: Lscr-104.bin / Lscr-104.json, mechanical analysis
-- MovieScript 4 - Socket Send Commands
-- Each handler builds a D-delimited socket message and calls ssm() to send it.
-- D = String.fromCharCode(30)
-- Constraint: every executable line comes from recovered bytecode evidence.

-- -----------------------------------------------------------------------
-- Session
-- -----------------------------------------------------------------------

on LOGIN
  -- no-op body (registration/prologue only; login is initiated via ssm in Lscr-109)
end

-- -----------------------------------------------------------------------
-- NIM (Buddy) Commands
-- -----------------------------------------------------------------------

on SENDNIMMESSAGE nimMsg
  ssm("L" & String.fromCharCode(30) & _global.guid)
end

on UPDATENIMUSER userID, userName
  ssm("SN" & String.fromCharCode(30) & userID & String.fromCharCode(30) & unescape(userName))
end

on DELETENIMUSER userID
  ssm("UNU" & String.fromCharCode(30) & userID)
end

on BLOCKNIMUSER userID
  ssm("DU" & String.fromCharCode(30) & userID)
end

on UNBLOCKNIMUSER userID
  ssm("BU" & String.fromCharCode(30) & userID)
end

on INQUIRYNIMUSER userID
  ssm("UU" & String.fromCharCode(30) & userID)
end

on ALLOWNIMUSER userName
  ssm("IU" & String.fromCharCode(30) & unescape(userName))
end

on NIMOKRESPONSE userID, status
  ssm("AU" & String.fromCharCode(30) & userID & String.fromCharCode(30) & status)
end

on DELETENIMINQUIREDUSER userID
  ssm("OR" & String.fromCharCode(30) & userID)
end

on GETNIMINREQUESTS userID
  ssm("DIU" & String.fromCharCode(30) & userID)
end

on GETNIMOUTREQUESTS
  ssm(GIR)
end

-- -----------------------------------------------------------------------
-- Race Chat Rooms
-- -----------------------------------------------------------------------

on LISTRACECHATROOMS2
  ssm(GOR)
end

on CREATECHATROOM roomID, roomName
  ssm("LRCR2" & String.fromCharCode(30) & roomID & String.fromCharCode(30) & roomName)
end

on JOINRACECHAT roomName, roomPass, p1, p2, p3, p4, p5
  roomName = unescape(roomName)
  roomPass = unescape(roomPass)
  ssm("CRC" & String.fromCharCode(30) & roomName & String.fromCharCode(30) & roomPass & \
      String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & \
      String.fromCharCode(30) & p3 & String.fromCharCode(30) & p4 & \
      String.fromCharCode(30) & p5)
end

on LEAVERACECHAT roomName, p1, p2, p3, p4
  roomName = unescape(roomName)
  ssm("JRC" & String.fromCharCode(30) & roomName & String.fromCharCode(30) & p1 & \
      String.fromCharCode(30) & p2 & String.fromCharCode(30) & p3 & \
      String.fromCharCode(30) & p4)
end

on LISTRACECHATUSERS
  ssm(LRC)
end

on SENDRACECHAT
  ssm(LRCU)
end

-- -----------------------------------------------------------------------
-- Team Commands
-- -----------------------------------------------------------------------

on TEAMKICK userName
  userName = unescape(userName)
  ssm("SRC" & String.fromCharCode(30) & userName)
end

on TEAMCHANGEROLE userID
  ssm("TK" & String.fromCharCode(30) & userID)
end

on TEAMUPDATEMAXBET p1, p2, p3
  ssm("TCR" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & String.fromCharCode(30) & p3)
end

on TEAMDEPOSIT amount, p2
  ssm("TUB" & String.fromCharCode(30) & amount & String.fromCharCode(30) & p2)
end

on TEAMWITHDRAW amount
  ssm("TDP" & String.fromCharCode(30) & amount)
end

on TEAMQUIT teamID
  ssm("TW" & String.fromCharCode(30) & teamID)
end

on TEAMACCEPT
  ssm(TQ)
end

on TEAMDISPERSE teamID
  ssm("TAT" & String.fromCharCode(30) & teamID)
end

on TEAMCREATE teamName, teamTag
  ssm("TDB" & String.fromCharCode(30) & teamName & String.fromCharCode(30) & teamTag)
end

on TEAMSTEPDOWN teamID
  ssm("TC" & String.fromCharCode(30) & unescape(teamID))
end

-- -----------------------------------------------------------------------
-- KOTH (King of the Hill)
-- -----------------------------------------------------------------------

on GETKOTH
  ssm(TL)
end

on JOINKOTH
  ssm(GK)
end

on LEAVEKOTH roomID, acid
  ssm("JK" & String.fromCharCode(30) & roomID & String.fromCharCode(30) & acid)
  _global.objRace.raceType = KOTH
  executeCall("getonecarengine", ("acid=" & roomID))
end

on KCNT
  ssm(LK)
end

on SENDVOTE roomID, voteTarget
  ssm("KC" & String.fromCharCode(30) & roomID & String.fromCharCode(30) & voteTarget)
  _global.objRace.init(KOTH)
end

on KDONE p1, p2
  ssm("SV" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2)
end

on KRT rt, rd, p1, p2, p3, p4, p5, p6, p7, p8, p9, p10, p11, p12, p13, p14, p15
  rt = Math.floor(rt * 1000) / 1000
  rd = Math.floor(rd * 100) / 100
  afterRD = Math.floor(afterRD * 1000) / 1000
  ssm("KD" & String.fromCharCode(30) & rt & String.fromCharCode(30) & rd & \
      String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & \
      String.fromCharCode(30) & p3 & String.fromCharCode(30) & p4 & \
      String.fromCharCode(30) & p5 & String.fromCharCode(30) & p6 & \
      String.fromCharCode(30) & p7 & String.fromCharCode(30) & p8 & \
      String.fromCharCode(30) & p9 & String.fromCharCode(30) & p10 & \
      String.fromCharCode(30) & p11 & String.fromCharCode(30) & p12 & \
      String.fromCharCode(30) & p13 & String.fromCharCode(30) & isCheatEngineRunning() & \
      String.fromCharCode(30) & afterRD & \
      String.fromCharCode(30) & CheckProcesses(decrypt(_global.cp)) & \
      String.fromCharCode(30) & CheckWindows(decrypt(_global.cw)) & \
      String.fromCharCode(30) & CheckWindowsClass(decrypt(_global.cwc)))
end

on STG rt, rd
  rt = Math.floor(rt * 1000) / 1000
  ssm("KRT" & String.fromCharCode(30) & rt & String.fromCharCode(30) & rd)
end

on int p1, p2, p3
  p1 = Math.floor(p1 * 1000) / 1000
  p2 = Math.floor(p2 * 1000) / 1000
  p3 = Math.floor(p3 * 1000) / 1000
  ssm("S" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & String.fromCharCode(30) & p3)
end

on KOK p1, p2, p3, p4
  p1 = Math.floor(p1 * 1000) / 1000
  p2 = Math.floor(p2 * 1000) / 1000
  p3 = Math.floor(p3 * 1000) / 1000
  ssm("I" & String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & \
      String.fromCharCode(30) & p3 & String.fromCharCode(30) & p4)
end

on KREADY raceID
  ssm("KOK" & String.fromCharCode(30) & raceID)
  _global.objRace.init(KOTH)
end

