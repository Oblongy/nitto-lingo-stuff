on HTQRT rt, rd, p1, p2, p3, p4, p5, p6, p7, p8, p9, p10, p11, p12, p13, p14, p15
  rt = Math.floor(rt * 1000) / 1000
  rd = Math.floor(rd * 100) / 100
  afterRD = Math.floor(afterRD * 1000) / 1000
  ssm("HTQD" & String.fromCharCode(30) & rt & String.fromCharCode(30) & rd & \
      String.fromCharCode(30) & p1 & String.fromCharCode(30) & p2 & \
      String.fromCharCode(30) & p3 & String.fromCharCode(30) & p4 & \
      String.fromCharCode(30) & p5 & String.fromCharCode(30) & p6 & \
      String.fromCharCode(30) & p7 & String.fromCharCode(30) & p8 & \
      String.fromCharCode(30) & p9 & String.fromCharCode(30) & p10 & \
      String.fromCharCode(30) & p11 & String.fromCharCode(30) & p12 & \
      String.fromCharCode(30) & p13 & String.fromCharCode(30) & isCheatEngineRunning() & \
      String.fromCharCode(30) & afterRD & \
      String.fromCharCode(30) & CheckProcesses(decrypt(_global.cp)) & \
      String.fromCharCode(30) & CheckWindows(decrypt(_global.cw)) & \
      String.fromCharCode(30) & CheckWindowsClass(decrypt(_global.cwc)))
end

