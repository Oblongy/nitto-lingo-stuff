-- -----------------------------------------------------------------------
-- Process / Anti-cheat
-- -----------------------------------------------------------------------

on IsMyProcessNameCorrect
  _player.quit()
end

on CheckNittoProcesses
  result = 0
  if _player.applicationName.search(_global.exeName) <> -1 then
    result = 1
  end if
  return result
end

on CheckNittoProcessesCB param1
  if not (_player.debugPlaybackEnabled = TRUE) then
    _global.checkedForOneClient = VOID
    _global.checkProcessResult = getNetText(_global.mainURL & "oneclient.html?hey=1")
  end if
end

